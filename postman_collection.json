{
	"info": {
		"_postman_id": "8a5df87e-0fcc-4948-ae7a-b44e4c385bb0",
		"name": "Manajemen Kasir API",
		"description": "Collection untuk testing API Manajemen Kasir (Hybrid Monolith) dengan auto-fetch CSRF token",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Get CSRF Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Ambil token CSRF dari JSON response",
									"var jsonData = pm.response.json();",
									"if (jsonData && jsonData.csrf_token) {",
									"    pm.environment.set(\"csrf_token\", jsonData.csrf_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/csrf-token",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"csrf-token"
							]
						},
						"description": "Ambil CSRF Token sebagai JSON sebelum melakukan request POST/PUT/DELETE"
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Simpan token CSRF terbaru setelah login",
									"var xsrfCookie = pm.cookies.get('XSRF-TOKEN');",
									"if (xsrfCookie) {",
									"    pm.environment.set(\"csrf_token\", decodeURIComponent(xsrfCookie));",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "X-XSRF-TOKEN",
								"value": "{{csrf_token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "email",
									"value": "superadmin@kasir.app",
									"type": "text"
								},
								{
									"key": "password",
									"value": "password",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"login"
							]
						}
					},
					"response": []
				}
			]
		},
